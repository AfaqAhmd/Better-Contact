# Server-only secret key for Better Contact API calls.
BETTERCONTACT_API_KEY=your_bettercontact_api_key_here

# ---- Testing / UI Freeze Mode ----
# When true, the API route will NOT call Better Contact.
# It will wait BETTERCONTACT_FREEZE_DELAY_MS and return a mocked result
# so you can test the loading animation.
# BETTERCONTACT_FREEZE=false
# BETTERCONTACT_FREEZE_MODE=found   # found | not_found
# BETTERCONTACT_FREEZE_DELAY_MS=12000
# BETTERCONTACT_FREEZE_PHONE=+1 (555) 123-4567
